// TSConfig des specs vitest : mêmes règles que l'app, plus les types Node
// (les specs tournent sous vite-node — node:fs, __dirname… y sont légitimes).
{
  "extends": "./tsconfig.app.json",
  "exclude": [],
  "compilerOptions": {
    "composite": true,
    "types": ["node"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo"
  }
}
