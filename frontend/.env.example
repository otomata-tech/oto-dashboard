# Config publique frontend (copier en .env pour le dev local)
VITE_LOGTO_ENDPOINT=https://auth.oto.zone
# Client SPA Logto — pré-créé via la Management API (pas de DCR), cf. skill logto-client.
# Pour tester en local contre les VRAIES données de prod (pas besoin de secret — un
# client_id PKCE SPA n'en est pas un) : copier les 4 valeurs VITE_LOGTO_*/
# VITE_OTO_MCP_BASE depuis .env.production. Détail : CLAUDE.md § "Tester un fix EN LOCAL
# contre les VRAIES données de prod".
VITE_LOGTO_APP_ID=
# Audience = API resource d'oto-mcp (le backend du dashboard)
VITE_LOGTO_AUDIENCE=https://mcp.oto.ninja/mcp
VITE_OTO_MCP_BASE=https://mcp.oto.ninja
# Analytics + session replay PostHog (Cloud EU). Laisser vide = analytics désactivé
# (dev local). Clé projet « phc_… » depuis eu.posthog.com → Project settings.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
# Error tracking Sentry (projet front « oto-dashboard », région EU). Laisser vide
# = désactivé (dev local). DSN public (sûr en clair, comme la clé PostHog phc_).
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=production

# URL MCP affichée (vitrine, découplée de l'audience OAuth). Défaut : https://mcp.oto.cx/mcp
# VITE_MCP_PUBLIC_URL=https://mcp.oto.cx/mcp
